{
  "lock": false,
  "version": "0.1.19",
  "unstable": ["kv"],
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check **/*.ts && deno check **/*.tsx",
    "cli": "echo \"import '\\$fresh/src/dev/cli.ts'\" | deno run --unstable -A -",
    "manifest": "deno task cli manifest $(pwd)",
    "start": "deno run -A --env --watch=static/,routes/ dev.ts",
    "build": "deno run -A bundling.ts && deno run -A dev.ts build",
    "preview": "deno run -A --env main.ts",
    "update": "deno run -A -r https://fresh.deno.dev/update .",
    "server": "deno run -A --env server.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*", "static/service-worker.js"
  ],
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "@preact-icons/tb": "jsr:@preact-icons/tb@^1.0.12",
    "@preact/signals": "npm:@preact/signals@^1.3.1",
    "@preact/signals-core": "npm:@preact/signals-core@^1.8.0",
    "@sholvoir/components/": "https://raw.esm.sh/gh/sholvoir/preact-components@0.0.9/",
    "@sholvoir/deno-smtp": "jsr:@sholvoir/deno-smtp@^0.9.9",
    "@sholvoir/dict/": "https://raw.esm.sh/gh/sholvoir/dict@0.0.2/",
    "@sholvoir/generic": "jsr:@sholvoir/generic@0.0.11",
    "@sholvoir/vocabulary": "jsr:@sholvoir/vocabulary@^0.0.30",
    "@std/http": "jsr:@std/http@^1.0.11",
    "esbuild": "npm:esbuild@^0.24.0",
    "esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.0",
    "js-cookie": "https://esm.sh/js-cookie@3.0.5",
    "mongodb": "npm:mongodb@^6.11.0",
    "preact": "npm:preact@^10.25.1",
    "preact/hooks": "npm:preact@^10.25.1/hooks",
    "preact/jsx-runtime": "npm:preact@^10.25.1/jsx-runtime",
    "tailwindcss": "npm:tailwindcss@^3.4.16",
    "tailwindcss/": "npm:/tailwindcss@^3.4.16/",
    "tailwindcss/plugin": "npm:/tailwindcss@^3.4.16/plugin.js"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
